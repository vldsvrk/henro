# BYOK: paste your key in Settings inside the app, or set it here for local dev.
# Used as a fallback when no key is saved in the browser. Never commit a real key
# and never set this in a hosted build — Vite inlines it into the client bundle.
# VITE_OPENROUTER_API_KEY=

# Debug mode: logs every AI prompt + response to the browser console.
# Set to "true" to enable. Unset/anything-else = off.
# VITE_HENRO_DEBUG=true
